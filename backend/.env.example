# PostgreSQL - Yerel geliştirme için örnek
# Windows: PostgreSQL kuruluysa genelde port 5432
# DATABASE_URL="postgresql://KULLANICI:SIFRE@localhost:5432/finwise?schema=public"

# Örnek (kullanıcı: postgres, şifre: postgres, veritabanı: finwise)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/finwise?schema=public"

# JWT - Production'da güçlü, rastgele bir değer kullanın
JWT_SECRET="finwise-super-guvenli-jwt-secret-degistirin-productionda"
JWT_EXPIRES_IN="7d"

# Opsiyonel: Sunucu portu (varsayılan 5000)
PORT=5000

# Canlı piyasa API ayarları (anahtarsız: Frankfurter + open.er-api + CoinGecko genel API)
MARKET_CACHE_TTL_MS=60000
# Opsiyonel: exchangeratesapi.io vb. (öncelikli döviz kaynağı)
EXCHANGE_API_KEY=""
EXCHANGE_API_BASE="https://api.exchangeratesapi.io/v1"
COINGECKO_API_BASE="https://api.coingecko.com/api/v3"
# Opsiyonel: CoinGecko Pro (x-cg-pro-api-key header)
COINGECKO_API_KEY=""
# Opsiyonel: metals-api.com ile XAU (CoinGecko yedeğinin üzerine yazar)
METALS_API_KEY=""
METALS_API_BASE="https://metals-api.com/api"
