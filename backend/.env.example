# PostgreSQL - Yerel geliştirme için örnek
# Windows: PostgreSQL kuruluysa genelde port 5432
# DATABASE_URL="postgresql://KULLANICI:SIFRE@localhost:5432/finwise?schema=public"

# Örnek (kullanıcı: postgres, şifre: postgres, veritabanı: finwise)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/finwise?schema=public"

# JWT - Production'da güçlü, rastgele bir değer kullanın
JWT_SECRET="finwise-super-guvenli-jwt-secret-degistirin-productionda"
JWT_EXPIRES_IN="7d"

# Opsiyonel: Sunucu portu (varsayılan 5000)
PORT=5000
